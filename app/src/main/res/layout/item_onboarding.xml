<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:layout_marginBottom="24dp"
    android:background="@color/background">

    <ImageView
        android:id="@+id/ivOnboarding"
        android:layout_width="3000dp"
        android:layout_height="300dp"
        android:scaleType="fitCenter"
        android:src="@drawable/onboarding_1"
        android:contentDescription="Onboarding item"/>

    <TextView
        android:id="@+id/tvOnboardingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:text="Welcome to Mini Bank"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textColor="@color/text_primary"
        android:layout_marginTop="24dp"
        android:gravity="center"/>

    <TextView
        android:id="@+id/tvOnboardingDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:gravity="center"
        android:text="Secure Mobile Banking App"
        android:textAlignment="center"
        android:layout_marginTop="12dp"/>


</LinearLayout>